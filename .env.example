# T-Food single-VPS production environment template.
# Copy to .env and replace every placeholder before launch.
# Do not commit real secrets.

# Core Django
DEBUG=False
APP_ENV=production
DJANGO_SECRET_KEY=replace-with-a-long-random-secret-at-least-50-characters
ALLOWED_HOSTS=your-domain.example,www.your-domain.example
CSRF_TRUSTED_ORIGINS=https://your-domain.example,https://www.your-domain.example
CORS_ALLOWED_ORIGINS=https://your-domain.example,https://www.your-domain.example
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
APP_PORT=80
PUBLIC_APP_URL=https://your-domain.example
DEFAULT_FROM_EMAIL=noreply@your-domain.example
LOG_LEVEL=INFO
DJANGO_SERVER_LOG_LEVEL=INFO
MONITORING_ENABLED=True
METRICS_ENABLED=True
ERROR_REPORTING_ENABLED=False
SLOW_QUERY_THRESHOLD_MS=500
PRIVATE_MEDIA_ROOT=/app/private_media
PUBLIC_MEDIA_ROOT=/app/media
RUN_MIGRATIONS=False
RUN_COLLECTSTATIC=False
ALLOW_LEGACY_GLOBAL_OPERATIONS_ACCESS=False

# PostgreSQL
POSTGRES_DB=tfood
POSTGRES_USER=tfood
POSTGRES_PASSWORD=replace-with-a-strong-database-password
# Optional external database URL. Leave blank when using the bundled db service.
DATABASE_URL=

# Redis separation
# DB 1 = Django cache/throttling, DB 2 = Celery broker, DB 3 = Celery results.
REDIS_URL=redis://redis:6379/1
CELERY_BROKER_URL=redis://redis:6379/2
CELERY_RESULT_BACKEND=redis://redis:6379/3
CELERY_WORKER_QUEUES=critical,dispatch,notifications,maintenance,default
CELERY_LOG_LEVEL=INFO
CELERY_BEAT_SCHEDULE_FILE=/app/celerybeat-schedule

# Background behavior
PAYMENT_TIMEOUT_MINUTES=15
NOTIFICATIONS_ASYNC_ENABLED=False
SEED_DEMO_DATA=False

# Throttling
THROTTLE_ANON_RATE=1000/day
THROTTLE_USER_RATE=5000/day
THROTTLE_LOGIN_RATE=10/minute
THROTTLE_REGISTER_RATE=5/hour
THROTTLE_REFRESH_RATE=60/minute
THROTTLE_PASSWORD_RESET_RATE=5/hour
THROTTLE_PASSWORD_CONFIRM_RATE=10/hour

# Email / SMTP
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.your-provider.example
EMAIL_PORT=587
EMAIL_HOST_USER=replace-with-smtp-username
EMAIL_HOST_PASSWORD=replace-with-smtp-password
EMAIL_USE_TLS=True

# Payments
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
