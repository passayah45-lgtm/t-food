{
  "name": "T-Food Codespaces Demo",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",
  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {}
  },
  "forwardPorts": [8088],
  "portsAttributes": {
    "8088": {
      "label": "T-Food demo",
      "onAutoForward": "notify"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-azuretools.vscode-docker",
        "ms-python.python"
      ]
    }
  },
  "postCreateCommand": "cp -n .env.codespaces.example .env || true"
}
