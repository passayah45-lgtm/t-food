# T-Food Codespaces demo environment.
# Copy to .env in GitHub Codespaces.
# Safe for temporary demo/testing only. Do not use this for production.

APP_ENV=development
DEBUG=True
DJANGO_SECRET_KEY=codespaces-demo-secret-not-for-production-change-me

POSTGRES_DB=tfood
POSTGRES_USER=tfood
POSTGRES_PASSWORD=codespaces-demo-db-password

ALLOWED_HOSTS=localhost,127.0.0.1,.app.github.dev
CSRF_TRUSTED_ORIGINS=https://*.app.github.dev,http://localhost:8088,http://127.0.0.1:8088
CORS_ALLOWED_ORIGINS=http://localhost:8088,http://127.0.0.1:8088
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
APP_PORT=8088
# Keep localhost for local Codespaces preview. For a shared public forwarded
# URL, update this to https://<codespace-name>-8088.app.github.dev if needed.
PUBLIC_APP_URL=http://localhost:8088

PUBLIC_MEDIA_ROOT=/app/media
PRIVATE_MEDIA_ROOT=/app/private_media
# Keep disabled so demo operations access uses OperationsStaffProfile.
ALLOW_LEGACY_GLOBAL_OPERATIONS_ACCESS=False
RUN_MIGRATIONS=True
RUN_COLLECTSTATIC=True
SEED_DEMO_DATA=False

MONITORING_ENABLED=True
METRICS_ENABLED=True
ERROR_REPORTING_ENABLED=False
SLOW_QUERY_THRESHOLD_MS=500
LOG_LEVEL=INFO

REDIS_URL=redis://redis:6379/1
CHANNEL_REDIS_URL=redis://redis:6379/4
CELERY_BROKER_URL=redis://redis:6379/2
CELERY_RESULT_BACKEND=redis://redis:6379/3
CELERY_WORKER_QUEUES=critical,dispatch,notifications,maintenance,default
PAYMENT_TIMEOUT_MINUTES=15
NOTIFICATIONS_ASYNC_ENABLED=False

# External providers stay inactive for Codespaces. Use COD only.
COD_ENABLED=True
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
